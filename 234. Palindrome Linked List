class Solution {
    public boolean isPalindrome(ListNode head) 
    {
        Deque<Integer> stack = new ArrayDeque<>();
        ListNode temp=head;
        while(temp!=null){
            stack.push(temp.val);
            temp=temp.next;
        }
        temp=head;
        while(temp!=null)
        {
            if(stack.pop() != temp.val) return false;
            temp=temp.next;
        }
        return true;
    }
}

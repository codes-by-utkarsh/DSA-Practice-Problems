class Solution {
    public ListNode middleNode(ListNode head) 
    {
        int c=0;
        ListNode temp = head;
        while(temp!=null)
        {
            ++c;
            temp=temp.next;
        }
        int middle = (c/2)+1;
        temp = head;
        while(temp!=null)
        {
            middle--;
            if(middle == 0) 
                return temp;
            temp=temp.next;            
        }
        return null;

    }
}

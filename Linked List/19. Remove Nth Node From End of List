class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {

        int len = 0;
        ListNode temp = head;

        while(temp != null) {
            len++;
            temp = temp.next;
        }

        int pos = len - n;

        if(pos == 0)
            return head.next;

        temp = head;

        int i = 1;
        while(i < pos) {
            temp = temp.next;
            i++;
        }

        temp.next = temp.next.next;

        return head;
    }
}
